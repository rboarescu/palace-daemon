[Unit]
Description=palace-daemon — MemPalace HTTP/MCP gateway
After=network.target

[Service]
Type=simple
# EDIT: set to your username
User=radu
# EDIT: set to the directory where main.py lives
WorkingDirectory=/home/radu/palace-daemon
# EDIT: set to your mempalace venv python (find with: pipx environment --value PIPX_LOCAL_VENVS)/mempalace/bin/python
ExecStart=/home/radu/.local/share/pipx/venvs/mempalace/bin/python main.py
# EDIT: uncomment and tune concurrency (default: 4 reads, 2 writes)
# Environment=PALACE_MAX_CONCURRENCY=4
# EDIT: uncomment to require an API key on all requests
# Environment=PALACE_API_KEY=your-secret
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
